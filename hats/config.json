{
  "id": "crowdgenome",
  "description": "Distributed Dark Genome mapping — crowd-sourced pangenome alignment via browser WASM",
  "type": "tracker",
  "lang": "en",
  "source": {
    "url": "https://chunks.zyrkel.com/api/stats",
    "method": "GET"
  },
  "condition": {
    "type": "extract_value",
    "selector": "$.genome_pct",
    "unit": "%"
  },
  "notify": {
    "telegram": true,
    "message": "CrowdGenome: {value}% genome coverage ({summary})"
  },
  "output_dir": "staging"
}
