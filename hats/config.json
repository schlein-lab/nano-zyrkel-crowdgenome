{
  "id": "crowdgenome",
  "description": "Distributed Dark Genome mapping — crowd-sourced pangenome alignment via browser WASM",
  "type": "pipeline",
  "lang": "en",
  "notify": { "telegram": false },
  "output_dir": "staging",
  "pipeline": {
    "manifest_url": "https://crowdgenome.fra1.digitaloceanspaces.com/ref/manifest.json",
    "manifest_items_path": "$.chromosomes.*.tile_list[*]",
